# OPC UA bridge configuration
OPC_SERVER_URL=opc.tcp://127.0.0.1:4840
OPC_USERNAME=
OPC_PASSWORD=
OPC_SECURITY_POLICY=Basic256Sha256
OPC_SECURITY_MODE=SignAndEncrypt

# Inference endpoint
INFERENCE_URL=http://127.0.0.1:8000/predict

# Model / scaler path
SCALER_PATH=./model/scaler_model.onnx

# Polling interval in seconds
POLL_INTERVAL_S=1800
